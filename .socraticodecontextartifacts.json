{
  "project_id": "gxiueukobiwamtcfaxrl",
  "project_name": "noctvm",
  "description": "Nightlife & Social Discovery Platform for Bucharest/Constanta",
  "artifacts": [
    {
      "name": "Database Schema (Public)",
      "type": "database_schema",
      "provider": "supabase",
      "schema_name": "public",
      "content": {
        "tables": [
          {
            "name": "profiles",
            "description": "User profile data including badges, bio, location, and social links.",
            "columns": ["id", "username", "display_name", "email", "avatar_url", "bio", "city", "badge", "created_at"]
          },
          {
            "name": "events",
            "description": "Scraped and manual events from ra, fever, zilesinopti, etc.",
            "columns": ["id", "title", "venue", "date", "time", "genres", "image_url", "event_url", "source", "city", "save_count"]
          },
          {
            "name": "venues",
            "description": "Club and bar locations with addresses, ratings, and descriptions.",
            "columns": ["id", "name", "address", "genres", "rating", "review_count", "description", "lat", "lng"]
          },
          {
            "name": "posts",
            "description": "Social feed content including images, captions, and links to events/venues.",
            "columns": ["id", "user_id", "caption", "image_url", "venue_name", "event_id", "likes_count", "created_at"]
          },
          {
            "name": "moonrays_wallets",
            "description": "Gamification wallet for user rewards and status.",
            "columns": ["id", "user_id", "balance", "net_earned", "status"]
          }
        ],
        "relationships": [
          "profiles.id -> auth.users.id",
          "posts.user_id -> profiles.id",
          "posts.event_id -> events.id",
          "venues.owner_id -> profiles.id"
        ]
      }
    },
    {
      "name": "API Metadata",
      "type": "api_spec",
      "provider": "supabase",
      "url": "https://gxiueukobiwamtcfaxrl.supabase.co"
    }
  ]
}
